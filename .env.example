# --- Database (Stage 0: SQLite, local-first; Postgres-ready via provider swap) ---
DATABASE_URL="file:./dev.db"

# --- Auth.js (NextAuth v5) ---
# Generate one with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET="replace-with-a-long-random-string"
# Trust the local host in dev
AUTH_TRUST_HOST=true

# --- Seeded admin login (created by prisma/seed.ts) ---
SEED_ADMIN_EMAIL="admin@govex.local"
SEED_ADMIN_PASSWORD="ChangeMe123!"

# --- Stage 2: Gemini synthesis ---
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"

# ============================================================================
# FUTURE — Keycloak 10.0.2 (OIDC) swap. Leave blank in Stage 0.
# When ready: fill these, add the Keycloak provider in lib/auth.ts, and the
# rest of the app (RBAC, routes, guards) is unchanged. See lib/auth.ts notes.
# ============================================================================
# AUTH_KEYCLOAK_ID=""
# AUTH_KEYCLOAK_SECRET=""
# AUTH_KEYCLOAK_ISSUER="http://localhost:8080/auth/realms/govex"
